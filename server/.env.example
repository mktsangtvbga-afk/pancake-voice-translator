# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Required: Gemini API key. Get one at https://aistudio.google.com/apikey
# This key lives ONLY on the server — it must never be shipped in the
# Chrome extension bundle.
GEMINI_API_KEY=

# Gemini model used for STT + language detection + translation.
GEMINI_MODEL=gemini-2.5-flash

# Port the Express server listens on. The extension's popup must point at
# this (e.g. http://localhost:5175).
PORT=5175

# Comma-separated list of allowed origins for CORS. Use the extension's
# origin, e.g. chrome-extension://<your-extension-id>. Leave "*" only for
# local development.
ALLOWED_ORIGINS=*

# Edge TTS voice used for "Nghe tiếng Việt". List other voices with
# `npx msedge-tts` or see Microsoft's Edge Read Aloud voice list.
TTS_VOICE=vi-VN-HoaiMyNeural

# Max upload size for a single voice message, in bytes (default 15MB).
MAX_AUDIO_BYTES=15728640
